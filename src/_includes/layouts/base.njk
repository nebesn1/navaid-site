<!doctype html>
{% set currentLang = lang or site.defaultLang %}
{% set siteName = "site.name" | t(currentLang) %}
{% set metaDescription = description or ("site.description" | t(currentLang)) %}
{% set isBlogPost = tags == "blog" or (tags and ("blog" in tags)) %}
<html lang="{{ currentLang }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="{{ metaDescription }}">
    <title>{% if title %}{{ title }} | {{ siteName }}{% else %}{{ siteName }}{% endif %}</title>
    <script>
      try {
        const savedTheme = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        document.documentElement.dataset.theme = savedTheme || (prefersDark ? "dark" : "light");
      } catch {
        document.documentElement.dataset.theme = "light";
      }
    </script>
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="stylesheet" href="/assets/css/style.css">
  </head>
  <body>
    {% include "components/header.njk" %}
    <main class="site-main"{% if isBlogPost %} data-pagefind-body{% endif %}>
      {% if isBlogPost %}
        <span hidden data-pagefind-filter="lang:{{ currentLang }}"></span>
        <span hidden data-pagefind-filter="section:blog"></span>
      {% endif %}
      {{ content | safe }}
    </main>
    <footer class="site-footer">
      <p>&copy; {{ siteName }}</p>
      <p>
        Powered by
        <a href="https://www.11ty.dev/" target="_blank" rel="noopener noreferrer">Eleventy</a>,
        <a href="https://www.cloudflare.com/" target="_blank" rel="noopener noreferrer">Cloudflare</a>,
        and
        <a href="https://github.com/" target="_blank" rel="noopener noreferrer">GitHub</a>.
      </p>
    </footer>
    <script src="/assets/js/theme.js" defer></script>
    <script src="/assets/js/language-switcher.js" defer></script>
    <script src="/assets/js/mobile-menu.js" defer></script>
    <script src="/assets/js/pagefind-blog-search.js" defer></script>
    <script src="/assets/js/console-log.js" defer></script>
  </body>
</html>
