---
title: 博客
layout: layouts/base.njk
description: 博客文章。
---

<h1>{{ "nav.blog" | t(lang) }}</h1>

{% set posts = collections.blog | byLang(lang) | reverse %}
{% if posts.length %}
  <ul class="post-list">
    {% for post in posts %}
      <li class="post-list__item">
        <article>
          <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
          <p class="post-meta">
            <time datetime="{{ post.date | htmlDateString }}">{{ post.date | formatDate(lang) }}</time>
          </p>
          {% if post.data.description %}
            <p>{{ post.data.description }}</p>
          {% endif %}
          <a class="read-more" href="{{ post.url }}">{{ "common.readMore" | t(lang) }}</a>
        </article>
      </li>
    {% endfor %}
  </ul>
{% else %}
  <p>暂无文章。</p>
{% endif %}
